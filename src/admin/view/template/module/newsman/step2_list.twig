{{ header }}{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <h1><img src="{{ logo }}" alt="{{ heading_title }}" style="height: 30px;" /></h1>
            <div class="form-text"><a href="https://www.newsman.com/" target="_blank">www.newsman.com</a> | {{ text_extension_version }}: {{ extension_version }}</div>
            <ol class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ol>
        </div>
    </div>

    <div class="container-fluid">
        <div id="alerts">
            {% if success %}
                <div class="alert alert-success alert-dismissible" role="alert">
                    <i class="fa-solid fa-check-circle" aria-hidden="true"></i>&nbsp;{{ success }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ text_close }}"></button>
                </div>
            {% endif %}
            {% if error %}
                <div class="alert alert-danger alert-dismissible" role="alert">
                    <i class="fa-solid fa-exclamation-triangle" aria-hidden="true"></i>&nbsp;{{ error }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ text_close }}"></button>
                </div>
            {% endif %}
            {% if warning %}
                <div class="alert alert-warning alert-dismissible" role="alert">
                    <i class="fa-solid fa-info-circle"></i>&nbsp;{{ warning }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}
        </div>
    </div>

    {% if error %}
        <div class="container-fluid">
            <h4>{{ text_step2_retry }}</h4>
            <div class="mt-2">
                <a style="background: #ad0100" href="{{ oauth_url }}"
                   class="btn btn-primary">{{ button_retry }}</a>
            </div>
        </div>
    {% else %}
        <div class="container-fluid">
            <div class="card mb-3">
                <div class="card-header">
                    <i class="fa-solid fa-pencil"></i> {{ text_step2_list_title }}
                    <span class="float-end"><b><i class="fa-solid fa-cog"></i> {{ text_setup_for_store }}</b></span>
                </div>
                <div class="card-body">
                    <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-email-list">
                        <div class="alert alert-info">
                            <i class="fa-solid fa-info-circle"></i> {{ text_step2_list_select_finalize }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <input type="hidden" name="user_id" value="{{ user_id }}"/>
                        <input type="hidden" name="api_key" value="{{ api_key }}"/>
                        <div class="row mb-3">
                            <label class="col-sm-2 col-form-label" for="email-list">{{ entry_list_id }}</label>
                            <div class="col-sm-10">
                                <select name="list_id" id="email-list" class="form-select">
                                    <option value="">{{ text_please_select_list }}</option>
                                    {% for email_list in email_lists %}
                                        <option {% if email_lists_length == 1 %}selected{% endif %} value="{{ email_list.id }}">{{ email_list.name }}</option>
                                    {% endfor %}
                                </select>
                                <span id="email-list-error" style="display: none; color: #ff0000;"><br />{{ text_step2_list_select_proceed }}</span>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-10 offset-sm-2">
                                <button type="button" class="btn btn-primary" id="save_action">{{ button_save }}</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <script type="text/javascript">
            (function($) {
                var formEmailList = $('#form-email-list');

                $(document).on('click', '#save_action', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if ($('#email-list').val() == '') {
                        $('#email-list-error').show();
                    } else {
                        $('#email-list-error').hide();
                        $(formEmailList).submit();
                    }
                });
            })(jQuery);
        </script>
    {% endif %}
</div>
{{ footer }}
